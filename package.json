{
  "name": "@donately/mcp",
  "version": "0.1.1",
  "description": "Donately MCP server — wraps the public developer documentation as an MCP toolset for AI assistants (Claude, Cursor, etc.)",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/donately/dntly-mcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/donately/dntly-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/donately/dntly-mcp/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "donately",
    "fundraising",
    "claude",
    "cursor"
  ],
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "donately-mcp": "dist/server.js"
  },
  "files": [
    "dist",
    "docs",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/server.js",
    "start": "node dist/server-http.js",
    "start:stdio": "node dist/server.js",
    "dev": "tsx watch src/server-http.ts",
    "dev:stdio": "tsx watch src/server.ts",
    "sync-docs": "tsx scripts/sync-docs.ts",
    "rebuild-corpus": "tsx scripts/convert-html-docs.ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run sync-docs && npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "express": "^5.0.0",
    "gray-matter": "^4.0.3",
    "zod": "^4.3.0"
  },
  "devDependencies": {
    "@joplin/turndown-plugin-gfm": "^1.0.64",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "cheerio": "^1.0.0",
    "tsx": "^4.19.0",
    "turndown": "^7.2.0",
    "typescript": "^5.6.0"
  }
}
